#!/bin/bash
# -----------------------------------------------------------------------------
# GenX VICIdial Installer launcher
# Logs to: /var/log/genx-install.log
# Reads version from: VERSION
# -----------------------------------------------------------------------------

set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
EXPRESS_SCRIPT="$SCRIPT_DIR/stage1-express.sh"
VERSION_FILE="$REPO_ROOT/VERSION"
LOG_FILE="/var/log/genx-install.log"

INSTALLER_VERSION="unknown"
[[ -f "$VERSION_FILE" ]] && INSTALLER_VERSION="$(cat "$VERSION_FILE" | tr -d '[:space:]')"

mkdir -p "$(dirname "$LOG_FILE")"
touch "$LOG_FILE"

log() {
    echo "$(date '+%F %T') [genx-install v${INSTALLER_VERSION}] $*" | tee -a "$LOG_FILE"
}

die() {
    log "ERROR: $*"
    exit 1
}

on_error() {
    local exit_code=$?
    local line_no=$1
    log "FAILED: command exited with code $exit_code at line $line_no"
    log "Review log: $LOG_FILE"
    exit "$exit_code"
}

trap 'on_error $LINENO' ERR

if [[ "${EUID:-$(id -u)}" -ne 0 ]]; then
    die "Run this installer as root."
fi

if [[ ! -x "$EXPRESS_SCRIPT" ]]; then
    die "Missing or non-executable: $EXPRESS_SCRIPT"
fi

clear
cat <<BANNER
==================================================
 GenX VICIdial Installer for AlmaLinux 9
 Version: ${INSTALLER_VERSION}
 Log:     ${LOG_FILE}
==================================================

Installer v1 focus:
  Express Server = Database + Web + Telephony

Future roles:
  Database Master
  Database Slave
  Web Server
  Telephony Server
  Archive Server

BANNER

log "Installer launcher started"
log "Repository root: $REPO_ROOT"

PS3="Select install role: "
select ROLE in \
    "Express Server - DB + Web + Telephony" \
    "Database Master - planned" \
    "Database Slave - planned" \
    "Web Server - planned" \
    "Telephony Server - planned" \
    "Archive Server - planned" \
    "Quit"; do
    case "$REPLY" in
        1)
            log "Selected Express Server install"
            exec "$EXPRESS_SCRIPT" --repo-root "$REPO_ROOT" --version "$INSTALLER_VERSION" --log-file "$LOG_FILE"
            ;;
        2|3|4|5|6)
            log "Selected planned role: $ROLE"
            echo "This role is planned for a later phase. Build and test Express first."
            ;;
        7)
            log "User exited installer"
            echo "Exiting."
            exit 0
            ;;
        *)
            echo "Invalid selection."
            ;;
    esac
done
